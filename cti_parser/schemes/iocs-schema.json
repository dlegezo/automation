{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "iocs-schema.json",
    "description": "Parsed CTI reports",
    "type": "object",
    "required": [
        "reports"
    ],
    "properties": {
        "reports": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "metadata",
                    "iocs",
                    "ttps"
                ],
                "properties": {
                    "metadata": {
                        "type": "object",
                        "required": [
                            "url",
                            "created",
                            "severity",
                            "confidence"
                        ],
                        "properties": {
                            "url": {
                                "type": "string",
                                "format": "uri",
                                "description": "URL of source CTI report, web or local file path"
                            },
                            "created": {
                                "type": "string",
                                "pattern": "^(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/([0-9]{4})$",
                                "description": "Date when the report was created, in format DD/MM/YYYY"
                            },
                            "severity": {
                                "type": "string",
                                "enum": [
                                    "low",
                                    "medium",
                                    "high",
                                    "critical"
                                ],
                                "description": "Severity level of the report based on victims geolocation and industry"
                            },
                            "confidence": {
                                "type": "string",
                                "enum": [
                                    "low",
                                    "medium",
                                    "high"
                                ],
                                "description": "Analyst confidence level for extracted report intelligence"
                            },
                            "tags": {
                                "type": "array",
                                "description": "List of tags associated with the report",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "iocs": {
                        "type": "array",
                        "description": "List of IOCs extracted from the report",
                        "items": {
                            "type": "object",
                            "required": [
                                "id",
                                "type",
                                "malign",
                                "value"
                            ],
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "pattern": "^ioc-[0-9]+$",
                                    "description": "Unique identifier for the IOC"
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "email",
                                        "ip",
                                        "domain",
                                        "url",
                                        "file",
                                        "process",
                                        "cmdline"
                                    ],
                                    "description": "Type of IOC"
                                },
                                "malign": {
                                    "type": "boolean",
                                    "description": "Indicates whether the IOC is considered malicious/detectable (true) or benign/just for information (false)"
                                },
                                "hash": {
                                    "type": "string",
                                    "enum": [
                                        "sha1",
                                        "sha256",
                                        "md5"
                                    ],
                                    "description": "Type of hash if the IOC type is 'file'"
                                },
                                "cert_serial": {
                                    "type": "string",
                                    "description": "Certificate serial number associated with file signing or TLS/SSL certificates for file, domain, or ip IOCs"
                                },
                                "value": {
                                    "type": "string",
                                    "description": "Value of the IOC"
                                },
                                "comment": {
                                    "type": "string",
                                    "description": "Additional comments or context about the IOC"
                                }
                            },
                            "allOf": [
                                {
                                    "if": {
                                        "properties": {
                                            "type": {
                                                "const": "file"
                                            }
                                        }
                                    },
                                    "then": {
                                        "required": [
                                            "hash"
                                        ]
                                    },
                                    "else": {
                                        "not": {
                                            "required": [
                                                "hash"
                                            ]
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": {
                                                "enum": [
                                                    "file",
                                                    "domain",
                                                    "ip"
                                                ]
                                            }
                                        }
                                    },
                                    "else": {
                                        "not": {
                                            "required": [
                                                "cert_serial"
                                            ]
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "vulns": {
                        "type": "array",
                        "description": "List of vulnerabilities associated with the report",
                        "items": {
                            "type": "object",
                            "required": [
                                "id",
                                "comment"
                            ],
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "pattern": "^CVE-[0-9]{4}-[0-9]{4,}$",
                                    "description": "CVE identifier for the vulnerability"
                                },
                                "comment": {
                                    "type": "string",
                                    "description": "Additional comments or context about the vulnerability"
                                }
                            }
                        }
                    },
                    "ttps": {
                        "type": "array",
                        "description": "List of TTPs associated with the report",
                        "items": {
                            "type": "object",
                            "required": [
                                "id",
                                "comment"
                            ],
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$",
                                    "description": "MITRE ATT&CK technique ID"
                                },
                                "comment": {
                                    "type": "string",
                                    "description": "Additional comments or context about the TTP"
                                }
                            }
                        }
                    },
                    "queries": {
                        "type": "array",
                        "description": "List of queries associated with the report",
                        "items": {
                            "type": "object",
                            "required": [
                                "id",
                                "type",
                                "value"
                            ],
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "pattern": "^query-[0-9]+$",
                                    "description": "Unique identifier for the query"
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "kql",
                                        "yara",
                                        "spl",
                                        "sigma",
                                        "sql"
                                    ],
                                    "description": "Type of query"
                                },
                                "value": {
                                    "type": "string",
                                    "description": "The query string used to search for the IOCs in security tools"
                                },
                                "iocs": {
                                    "type": "array",
                                    "description": "List of IOC IDs that this query is associated with",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "ttps": {
                                    "type": "array",
                                    "description": "List of TTP IDs that this query is associated with",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "comment": {
                                    "type": "string",
                                    "description": "Additional comments or context about the query"
                                }
                            }
                        }
                    },
                    "xrefs": {
                        "type": "array",
                        "description": "List of cross-references associated with the report",
                        "items": {
                            "type": "object",
                            "required": [
                                "id",
                                "type"
                            ],
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "pattern": "^xref-[0-9]+$",
                                    "description": "Unique identifier for the cross-reference"
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "creates",
                                        "uses"
                                    ],
                                    "description": "Type of this cross-reference"
                                },
                                "from": {
                                    "type": "array",
                                    "description": "List of source entity IDs for this relationship",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "to": {
                                    "type": "array",
                                    "description": "List of target entity IDs for this relationship",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "comment": {
                                    "type": "string",
                                    "description": "Additional comments or context about this cross-reference"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}