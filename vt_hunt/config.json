{
  "pipeline": {
    "required_env": ["VT_TOKEN", "VT_IOC_STREAM_URL", "VT_FILE_ITW_DOMAINS_URL", 
      "GIST_ID", "GIST_TOKEN", "GIST_UPDATE_URL"],
    "sources": [
      {
        "name": ["muddywater_dropper_dinodance_vbs", 
          "muddywater_launcher_dinodance", 
          "muddywater_backdoor_dinodance", 
          "muddywater_ateraagent",
          "muddywater_rotrot_strings",
          "muddywater_muddyc2go_launcher"],
        "type": "vt_ioc_stream",
        "format": "api",
        "token_env": "VT_TOKEN",
        "ioc_url_env": "VT_IOC_STREAM_URL",
        "domains_url_env": "VT_FILE_ITW_DOMAINS_URL",
        "limit": 15
      },
      {
        "type": "gist_to_check",
        "format": "csv",
        "gist_id_env": "GIST_ID",
        "token_env": "GIST_TOKEN",
        "url_env": "GIST_UPDATE_URL",
        "filename": "to_check.csv"
        }
    ],
    "outputs": [
      {
        "type": "gist",
        "gist_id_env": "GIST_ID",
        "token_env": "GIST_TOKEN",
        "url_env": "GIST_UPDATE_URL",
        "filename": "iocs.csv"
      }
    ]
  }
}
